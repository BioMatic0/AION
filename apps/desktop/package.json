{
  "name": "@aion/desktop",
  "version": "0.1.1",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "description": "Windows-Desktop-Wrapper fuer die AION-Anwendung.",
  "author": "Patrick Wirth",
  "copyright": "Copyright (c) 2026 Patrick Wirth. Released under the AION Community Fairness License 1.0.",
  "main": "build/main.js",
  "scripts": {
    "dev": "tsc -p tsconfig.json && electron .",
    "build": "tsc -p tsconfig.json",
    "prepare:runtime": "node scripts/prepare-runtime.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node -e \"console.log('No tests yet for @aion/desktop')\"",
    "package:win": "node scripts/prepare-runtime.mjs && electron-builder --win nsis portable",
    "package:win:publish": "node scripts/prepare-runtime.mjs && electron-builder --win nsis portable --publish always"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "electron": "^35.1.5",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.2"
  },
  "build": {
    "appId": "com.patrickwirth.aion.desktop",
    "productName": "AION",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "BioMatic0",
        "repo": "AION",
        "releaseType": "release"
      }
    ],
    "files": [
      "build/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../web/out",
        "to": "web"
      },
      {
        "from": "api-runtime",
        "to": "api",
        "filter": [
          "**/*",
          "node_modules/**/*",
          "node_modules/.pnpm/**/*",
          ".pnpm/**/*"
        ]
      }
    ],
    "win": {
      "icon": "build-resources/aion.ico",
      "signAndEditExecutable": false,
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build-resources/aion.ico",
      "uninstallerIcon": "build-resources/aion.ico",
      "installerHeaderIcon": "build-resources/aion.ico"
    },
    "generateUpdatesFilesForAllChannels": true
  },
  "dependencies": {
    "@aion/ai-core": "workspace:*",
    "@aion/governance": "workspace:*",
    "@aion/shared-types": "workspace:*",
    "@nestjs/common": "^11.0.12",
    "@nestjs/core": "^11.0.12",
    "@nestjs/platform-express": "^11.0.12",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  }
}
